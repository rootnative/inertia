{
  "name": "inertia-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace root for @rootnative/inertia — a wrapper around react-native-reanimated that makes the animation system easier.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "example": "pnpm --filter @rootnative/inertia-example start",
    "example:ios": "pnpm --filter @rootnative/inertia-example ios",
    "example:android": "pnpm --filter @rootnative/inertia-example android",
    "docs:dev": "pnpm --filter @rootnative/inertia-docs dev",
    "docs:build": "pnpm --filter @rootnative/inertia-docs build",
    "docs:serve": "pnpm --filter @rootnative/inertia-docs serve",
    "build:llms": "node scripts/build-llms.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "^14.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
