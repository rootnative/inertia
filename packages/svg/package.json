{
  "name": "@rootnative/inertia-svg",
  "version": "0.0.0-alpha.0",
  "description": "Animatable SVG primitives (path morphing, fill/stroke) for @rootnative/inertia, built on react-native-svg.",
  "license": "MIT",
  "author": "RootNative",
  "homepage": "https://github.com/rootnative/inertia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rootnative/inertia.git",
    "directory": "packages/svg"
  },
  "bugs": {
    "url": "https://github.com/rootnative/inertia/issues"
  },
  "keywords": [
    "react-native",
    "reanimated",
    "svg",
    "path",
    "morph",
    "animation",
    "inertia"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "llms.txt",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "!**/__tests__",
    "!**/*.test.*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "node ../../scripts/build-llms.mjs"
  },
  "peerDependencies": {
    "@rootnative/inertia": ">=0.0.0-alpha.0",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-svg": ">=15.0.0"
  },
  "devDependencies": {
    "@rootnative/inertia": "workspace:*",
    "@react-native/babel-preset": "^0.81.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "~15.13.0",
    "react-test-renderer": "19.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
