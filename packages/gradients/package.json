{
  "name": "@onlynative/inertia-gradients",
  "version": "0.0.1-alpha.5",
  "description": "Animated linear gradient primitive for @onlynative/inertia, built on expo-linear-gradient.",
  "license": "MIT",
  "author": "OnlyNative",
  "homepage": "https://github.com/onlynative/inertia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onlynative/inertia.git",
    "directory": "packages/gradients"
  },
  "bugs": {
    "url": "https://github.com/onlynative/inertia/issues"
  },
  "keywords": [
    "react-native",
    "reanimated",
    "gradient",
    "linear-gradient",
    "animation",
    "inertia",
    "expo"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "!**/__tests__",
    "!**/*.test.*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "@onlynative/inertia": ">=0.0.1-alpha.5",
    "expo-linear-gradient": ">=14.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-reanimated": ">=4.0.0"
  },
  "devDependencies": {
    "@onlynative/inertia": "workspace:*",
    "@react-native/babel-preset": "^0.81.5",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "expo-linear-gradient": "~14.0.2",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-test-renderer": "19.1.0",
    "size-limit": "^11.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
